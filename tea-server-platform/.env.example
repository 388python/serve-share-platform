# LinuxDo OAuth 配置 (必需)
LINUXDO_CLIENT_ID=你的client_id
LINUXDO_CLIENT_SECRET=你的client_secret
LINUXDO_REDIRECT_URI=https://你的域名/auth/callback

# 平台配置
PLATFORM_DOMAIN=https://你的域名

# 数据库 (可选，使用默认)
# DATABASE_URL=sqlite:tea_platform.db?mode=rwc

# 会话密钥 (可选，使用默认值)
# SESSION_SECRET=change-me-to-random-string

# 管理后台 (可选)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
